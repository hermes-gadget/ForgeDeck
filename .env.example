# ForgeDeck binds to the LAN by default. Override the port if needed.
FORGEDECK_HOST=0.0.0.0
FORGEDECK_PORT=4173

# Set this to off to skip the ForgeDeck login screen. Only do this on a
# private, trusted network; every device that can reach the port gets access.
# FORGEDECK_AUTH=off

# Optional: set a memorable login password. If omitted, ForgeDeck generates a
# strong access token in .data/access-token (which is ignored by git).
# FORGEDECK_PASSWORD=replace-me

# Colon-separated directories that may be selected as Codex workspaces.
# Defaults to the account's home directory.
# FORGEDECK_ROOTS=/home/you/projects:/srv/work

# Override this only when `codex` is not on the service PATH.
# CODEX_BIN=/absolute/path/to/codex
