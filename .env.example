# Network and paths
FORGEDECK_HOST=127.0.0.1
FORGEDECK_PORT=4173
# Non-loopback binds fail closed unless this acknowledgement is enabled.
# FORGEDECK_ALLOW_LAN=on
# Canonical browser origin. Required for wildcard binds and TLS reverse proxies.
# FORGEDECK_PUBLIC_ORIGIN=https://deck.example.test
# FORGEDECK_DATA_DIR=.data
# FORGEDECK_DIST_DIR=dist
# FORGEDECK_ROOTS=/home/you/projects:/srv/work

# Authentication. Disabling this grants every reachable device full access.
# FORGEDECK_AUTH=off
# FORGEDECK_PASSWORD=replace-with-at-least-12-characters
# Enables POST /api/webhook/trigger. Generate a long random value and keep it out of source control.
# FORGEDECK_WEBHOOK_SECRET=replace-with-a-random-webhook-secret
# Use "on" behind HTTPS, "auto" to follow the request protocol, or "off" for HTTP-only LAN use.
FORGEDECK_COOKIE_SECURE=auto
# Enable only when ForgeDeck is behind one trusted reverse-proxy hop. Block direct backend access.
FORGEDECK_TRUST_PROXY=off

# Comma-separated browser origins allowed to make credentialed cross-origin requests.
# Wildcards are rejected. FORGEDECK_ALLOWED_ORIGINS and FORGEDECK_CORS_ORIGINS remain aliases.
# FORGEDECK_TRUSTED_ORIGINS=https://deck.example.test,http://localhost:5173

# API protection and session lifecycle
FORGEDECK_RATE_LIMIT=300
FORGEDECK_RATE_WINDOW_MS=60000
# Browser tokens expire absolutely after this interval; active use does not extend them.
FORGEDECK_AUTH_SESSION_TTL_HOURS=24
FORGEDECK_AUTH_MAX_SESSIONS=32
FORGEDECK_LOGIN_MAX_ATTEMPTS=5
FORGEDECK_LOGIN_WINDOW_MS=900000
FORGEDECK_LOGIN_ATTEMPT_STATE_MAX=1000
FORGEDECK_LOGIN_GLOBAL_MAX_ATTEMPTS=200
# Set to 0 to disable automatic archival of idle sessions.
FORGEDECK_SESSION_TTL_HOURS=24
FORGEDECK_QUEUE_MAX_MESSAGES=100

# Work admission. Remaining provider quota at or below this percentage is reserved as headroom.
FORGEDECK_QUOTA_HEADROOM_PERCENT=10
FORGEDECK_QUOTA_RESET_PROXIMITY_MS=300000
FORGEDECK_QUOTA_STALE_MS=300000
# Exhaustion defaults to waiting for a known reset/retry time. "pause" requires an operator/user wake-up.
FORGEDECK_ADMISSION_POLICY=wait
# Optional versioned estimates, kept separately from raw usage facts. Rates are currency micros per million tokens.
# FORGEDECK_COST_CATALOG_JSON={"version":"operator-2026-07","currency":"USD","models":{"model-id":{"inputTokens":0,"outputTokens":0,"cachedInputTokens":0,"reasoningOutputTokens":0}}}

# Performance and reliability limits
# Shared adapter/store pools. Background work reserves one slot for interactive requests.
FORGEDECK_READ_MAX_CONCURRENT=16
FORGEDECK_MUTATION_MAX_CONCURRENT=5
FORGEDECK_MAINTENANCE_CHUNK_SIZE=25
FORGEDECK_MODEL_CACHE_TTL_MS=30000
FORGEDECK_CLAUDE_AVAILABILITY_CACHE_TTL_MS=30000
FORGEDECK_SLOW_REQUEST_MS=750
FORGEDECK_SHUTDOWN_TIMEOUT_MS=10000
# Total UTF-8 recovery payload retained for each active/recently viewed thread (256-512 KiB)
FORGEDECK_LIVE_OUTPUT_BUDGET_BYTES=393216
FORGEDECK_SSE_EVENT_MAX_BYTES=1000000

# Read-only monitoring of other local Codex processes
FORGEDECK_EXTERNAL_MONITOR=on
FORGEDECK_EXTERNAL_MONITOR_POLL_MS=1000
FORGEDECK_EXTERNAL_MONITOR_LIVENESS_MS=2500
FORGEDECK_EXTERNAL_MONITOR_THREAD_LIMIT=32
FORGEDECK_EXTERNAL_MONITOR_MAX_READ_BYTES=524288

# Persistent metadata, audit, and MCP actor retention
FORGEDECK_METADATA_RETENTION_HOURS=720
FORGEDECK_AUDIT_RETENTION_HOURS=720
FORGEDECK_AUDIT_MAX_BYTES=10485760
FORGEDECK_MCP_ACTOR_LIFETIME_HOURS=168
FORGEDECK_MCP_ACTOR_INACTIVITY_TTL_HOURS=24

# Runtime integration and logging
# CODEX_BIN=/absolute/path/to/codex
# FORGEDECK_CLAUDE_BIN=/absolute/path/to/claude
# FORGEDECK_CLAUDE_MAX_CONCURRENT=4
# FORGEDECK_CLAUDE_TTL_HOURS=2
# CODEX_HOME=/home/you/.codex
# CODEX_APP_SERVER_URL=ws://127.0.0.1:PORT
FORGEDECK_LOG_LEVEL=info
FORGEDECK_REQUEST_LOG_SAMPLE_RATE=1

# MCP clients only
# FORGEDECK_URL=http://127.0.0.1:4173
# FORGEDECK_MCP_TOKEN_FILE=.data/mcp-token
# Use a distinct stable value for each MCP client that should own sessions independently.
# FORGEDECK_MCP_CLIENT_ID=forgedeck-stdio

# Build-time diagnostics. Source maps are disabled by default in production.
# FORGEDECK_SOURCEMAP=true
