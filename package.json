{
  "name": "forgedeck",
  "version": "0.1.0",
  "private": true,
  "description": "A persistent, local-first web command deck for Codex sessions.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"tsx watch src/server/index.ts\" \"vite --host 0.0.0.0\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node --env-file-if-exists=.env build/server/index.js",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "node --test build/server/**/*.test.js",
    "install-service": "node scripts/install-service.mjs",
    "uninstall-service": "node scripts/uninstall-service.mjs"
  },
  "dependencies": {
    "express": "^5.1.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  },
  "engines": {
    "node": ">=22"
  }
}
