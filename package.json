{
  "name": "forgedeck",
  "version": "0.1.0",
  "private": true,
  "description": "A persistent, local-first web command deck for Codex sessions.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"tsx watch src/server/index.ts\" \"vite --host 0.0.0.0\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:analyze": "FORGEDECK_ANALYZE=true vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node --env-file-if-exists=.env build/server/index.js",
    "mcp": "node --env-file-if-exists=.env build/server/mcp.js",
    "mcp:dev": "tsx src/server/mcp.ts",
    "check": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "test": "npm run build:server && node --test build/server/**/*.test.js",
    "test:coverage": "npm run build:server && node --test --experimental-test-coverage build/server/**/*.test.js",
    "install-service": "node scripts/install-service.mjs",
    "uninstall-service": "node scripts/uninstall-service.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/server": "^2.0.0-beta.3",
    "express": "^5.1.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.4"
  },
  "engines": {
    "node": ">=22"
  }
}
