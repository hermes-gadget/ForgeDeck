{
  "name": "forgedeck",
  "version": "0.1.0",
  "private": true,
  "description": "A persistent, local-first web command deck for Codex sessions.",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,web -c cyan,magenta \"FORGEDECK_TRUSTED_ORIGINS=http://127.0.0.1:5173 tsx watch src/server/index.ts\" \"vite --host 127.0.0.1\"",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build",
    "build:analyze": "FORGEDECK_ANALYZE=true vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node --env-file-if-exists=.env build/server/index.js",
    "mcp": "node --env-file-if-exists=.env build/server/mcp.js",
    "mcp:dev": "tsx src/server/mcp.ts",
    "check": "npm run typecheck",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "test": "node --import tsx --test 'src/**/*.test.ts'",
    "test:coverage": "node --import tsx --test --experimental-test-coverage 'src/**/*.test.ts'",
    "test:a11y": "playwright test",
    "quality": "npm run quality:unused && npm run quality:deps",
    "quality:unused": "node scripts/check-unused.mjs",
    "quality:deps": "knip --include dependencies,devDependencies,unlisted,unresolved,binaries",
    "audit": "npm audit --audit-level=high",
    "docs:config": "tsx scripts/generate-config-docs.ts",
    "ci": "npm run typecheck && npm run lint && npm run test:coverage && npm run build && npm run test:a11y && npm run quality && npm run audit",
    "install-service": "node scripts/install-service.mjs",
    "uninstall-service": "node scripts/uninstall-service.mjs"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/outfit": "^5.2.8",
    "@modelcontextprotocol/server": "2.0.0-beta.3",
    "express": "^5.1.0",
    "lucide-react": "^0.525.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^9.39.5",
    "@playwright/test": "^1.61.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/express": "^5.0.3",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^24.0.13",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.6.0",
    "concurrently": "^9.2.0",
    "eslint": "^9.39.5",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "jsdom": "^26.1.0",
    "knip": "^6.27.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.23.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^7.0.4"
  },
  "engines": {
    "node": ">=22"
  }
}
